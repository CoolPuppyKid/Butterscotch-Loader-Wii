if(NOT DEFINED INPUT_ROOT)
    message(FATAL_ERROR "INPUT_ROOT is required")
endif()
if(NOT DEFINED OUTPUT_C)
    message(FATAL_ERROR "OUTPUT_C is required")
endif()
if(NOT DEFINED FILE_LIST)
    message(FATAL_ERROR "FILE_LIST is required")
endif()

file(WRITE "${OUTPUT_C}" "/* Auto-generated by cmake/embed_directory.cmake */\n")
file(APPEND "${OUTPUT_C}" "#include <stddef.h>\n")
file(APPEND "${OUTPUT_C}" "#include <stdint.h>\n")
file(APPEND "${OUTPUT_C}" "#include \"wii/wii_embedded_data.h\"\n\n")

file(APPEND "${OUTPUT_C}" "typedef struct {\n")
file(APPEND "${OUTPUT_C}" "    const char* path;\n")
file(APPEND "${OUTPUT_C}" "    const uint8_t* data;\n")
file(APPEND "${OUTPUT_C}" "    size_t size;\n")
file(APPEND "${OUTPUT_C}" "} WiiEmbeddedDataEntry;\n\n")

set(entry_lines "")
set(index 0)
foreach(rel_path IN LISTS FILE_LIST)
    set(abs_path "${INPUT_ROOT}/${rel_path}")
    if(IS_DIRECTORY "${abs_path}")
        continue()
    endif()

    string(REPLACE "\\" "/" rel_path "${rel_path}")
    string(REGEX REPLACE "[^A-Za-z0-9_]" "_" symbol "${rel_path}")
    set(symbol "wii_embedded_${index}_${symbol}")

    file(READ "${abs_path}" file_hex HEX)
    string(LENGTH "${file_hex}" hex_len)

    file(APPEND "${OUTPUT_C}" "static const uint8_t ${symbol}[] = {")
    if(hex_len GREATER 0)
        math(EXPR last_index "${hex_len} - 2")
        foreach(pos RANGE 0 ${last_index} 2)
            string(SUBSTRING "${file_hex}" ${pos} 2 byte_hex)
            file(APPEND "${OUTPUT_C}" "0x${byte_hex},")
        endforeach()
    endif()
    file(APPEND "${OUTPUT_C}" "};\n")
    string(APPEND entry_lines "    {\"${rel_path}\", ${symbol}, sizeof(${symbol})},\n")
    math(EXPR index "${index} + 1")
endforeach()

file(APPEND "${OUTPUT_C}" "\nstatic const WiiEmbeddedDataEntry kWiiEmbeddedDataEntries[] = {\n${entry_lines}};\n\n")
file(APPEND "${OUTPUT_C}" "const WiiEmbeddedDataEntryPublic g_wiiEmbeddedDataEntries[] = {\n")
file(APPEND "${OUTPUT_C}" "#define WII_EMBEDDED_ENTRY(idx) { kWiiEmbeddedDataEntries[idx].path, kWiiEmbeddedDataEntries[idx].data, kWiiEmbeddedDataEntries[idx].size }\n")
if(index GREATER 0)
    math(EXPR last_entry "${index} - 1")
    foreach(i RANGE 0 ${last_entry})
        file(APPEND "${OUTPUT_C}" "    WII_EMBEDDED_ENTRY(${i}),\n")
    endforeach()
endif()
file(APPEND "${OUTPUT_C}" "#undef WII_EMBEDDED_ENTRY\n};\n\n")
file(APPEND "${OUTPUT_C}" "const size_t g_wiiEmbeddedDataEntryCount = sizeof(g_wiiEmbeddedDataEntries) / sizeof(g_wiiEmbeddedDataEntries[0]);\n")
